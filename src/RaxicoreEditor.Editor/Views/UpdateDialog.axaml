<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RaxicoreEditor.Editor.Views.UpdateDialog"
        x:CompileBindings="False"
        Title="Update Available"
        Width="520" Height="440"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/icon.png"
        Background="{DynamicResource WindowBackgroundBrush}">
  <DockPanel Margin="24,20">
    <!-- Header -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="14">
      <Image Source="/Assets/icon.png" Width="44" Height="44" VerticalAlignment="Top"
             RenderOptions.BitmapInterpolationMode="HighQuality" />
      <StackPanel Spacing="2" VerticalAlignment="Center">
        <TextBlock x:Name="HeadlineText" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}" />
        <TextBlock x:Name="CurrentText" FontSize="12"
                   Foreground="{DynamicResource SubtleTextBrush}" />
      </StackPanel>
    </StackPanel>

    <!-- Footer: progress + actions -->
    <StackPanel DockPanel.Dock="Bottom" Spacing="10" Margin="0,14,0,0">
      <StackPanel x:Name="ProgressPanel" Spacing="4" IsVisible="False">
        <ProgressBar x:Name="DownloadProgress" Minimum="0" Maximum="1" Height="8" MinHeight="8"
                     Foreground="{DynamicResource AccentSecondaryBrush}" />
        <TextBlock x:Name="ProgressText" FontSize="11"
                   Foreground="{DynamicResource SubtleTextBrush}" />
      </StackPanel>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button x:Name="SkipButton" Content="Skip This Version" Click="OnSkip"
                Padding="10,4" />
        <Button x:Name="LaterButton" Content="Remind Me Later" Click="OnLater"
                Padding="10,4" />
        <Button x:Name="InstallButton" Content="Download &amp; Install" Click="OnInstall"
                Padding="12,4" FontWeight="SemiBold"
                Background="{DynamicResource AccentPrimaryBrush}" Foreground="#FAFAFA" />
      </StackPanel>
    </StackPanel>

    <!-- Release notes -->
    <Border BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="1" CornerRadius="4"
            Margin="0,16,0,0" Background="{DynamicResource EditorBackgroundBrush}">
      <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,8">
        <StackPanel Spacing="4">
          <TextBlock Text="What's new" FontSize="11" FontWeight="SemiBold"
                     Foreground="{DynamicResource AccentTertiaryBrush}" />
          <TextBlock x:Name="NotesText" TextWrapping="Wrap" FontSize="12"
                     Foreground="{DynamicResource TextBrush}"
                     FontFamily="Cascadia Code,Consolas,monospace" />
        </StackPanel>
      </ScrollViewer>
    </Border>
  </DockPanel>
</Window>
